# ─────────────────────────────────────────────
#  Environment Variables — copy to .env
# ─────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB — replace with your Atlas connection string
MONGO_URI=mongodb://localhost:27017/collab_notes
# MONGO_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/collab_notes?retryWrites=true&w=majority

# JWT — use a long random string in production
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# Cookie
COOKIE_SECURE=false          # set true in production (HTTPS only)
COOKIE_SAME_SITE=lax         # 'none' in production if cross-origin

# CORS — comma-separated allowed origins
CLIENT_ORIGIN=http://localhost:3000
